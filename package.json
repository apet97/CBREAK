{
  "name": "breakcheck-addon",
  "version": "1.0.0",
  "description": "Break compliance checker add-on for Clockify",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write \"js/**/*.{js,ts}\"",
    "format:check": "prettier --check \"js/**/*.{js,ts}\"",
    "typecheck": "tsc --noEmit",
    "build": "node build.js",
    "build:prod": "node build.js --production",
    "build:watch": "node build.js --watch"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.56.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "@types/jest": "^30.0.0",
    "typescript": "^5.9.3"
  },
  "keywords": ["clockify", "break-compliance", "labor-law", "addon"],
  "author": "Break Compliance Team",
  "license": "MIT"
}
